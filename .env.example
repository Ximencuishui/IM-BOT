# 应用配置
DEBUG=False
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# 平台数据库配置
SUPABASE_URL=postgresql://neondb_owner:npg_JhrxmMfCY92c@ep-solitary-leaf-aoflwxf0-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# 桌面端本地数据库类型: sqlite (默认,无需配置) / mysql (生产环境)
DB_TYPE=sqlite

# SQLite配置 (DB_TYPE=sqlite时使用)
SQLITE_DB_PATH=data/food_delivery.db

# MySQL配置 (DB_TYPE=mysql时使用)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=food_delivery

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# RabbitMQ配置
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# Elasticsearch配置
ES_HOST=localhost
ES_PORT=9200
ES_USER=
ES_PASSWORD=

# Flask服务配置
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# 业务配置
CUTOFF_TIME=21:30
PARSE_CONFIDENCE_THRESHOLD=0.7
MESSAGE_DEDUP_TTL=86400

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=logs

# CORS配置
CORS_ORIGINS=*

# 邮件配置 (可选)
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your_smtp_auth_code
FROM_EMAIL=your_email@qq.com
REPORT_RECIPIENTS=admin@example.com,manager@example.com

# 授权服务配置
LICENSE_API_BASE=https://api.fooddelivery.com

# AI 解析配置 (MCP - Model Context Protocol)
# 启用AI解析：true/false
AI_PARSER_ENABLED=false
# AI提供商：openai / deepseek / qwen / custom_http
AI_PARSER_PROVIDER=custom_http
# AI API地址（custom_http模式下必填）
AI_PARSER_API_URL=http://localhost:8000/v1/chat/completions
# AI API密钥（OpenAI/DeepSeek/通义千问需要）
AI_PARSER_API_KEY=
# AI模型名称
AI_PARSER_MODEL=deepseek-chat
# 请求超时时间（秒）
AI_PARSER_TIMEOUT=15
# 温度参数（0-1，越低越确定性）
AI_PARSER_TEMPERATURE=0.3

# VXHook / PC 微信 Hook（参考 sim-bot-node，控制面默认 19088）
HOOK_DLL_HTTP_PORT=19088
HOOK_API_BASE=http://127.0.0.1:19088
HOOK_API_TOKEN=8888
HOOK_RECEIVE_MODE=http
HOOK_CALLBACK_URL=http://127.0.0.1:5000/api/recvMsg
# HOOK_CALLBACK_PORT=0
# TCP_PORT=61108
# WECHAT_HK_DIR=D:\path\to\hk
# 微信安装路径（冷注入关闭微信后若自动找不到 exe，请填写）
# WECHAT_EXE_PATH=C:\Program Files\Tencent\Weixin\Weixin.exe
# AUTO_WECHAT_INJECT=0
# 桌面端默认冷注入（先关微信再注入，推荐保持 1）
# WECHAT_QUIT_BEFORE_INJECT=1
BOT_INBOUND_ENABLED=true
HOOK_ENABLED=true

# SimBot 管理平台（桌面端主程序授权：卡密由管理平台签发，在此核销）
SIMBOT_PLATFORM_URL=
SIMBOT_PLATFORM_TOKEN=
ACTIVATION_PUBLIC_KEY=config/activation_public.pem
ACTIVATION_CARD_SECRET=
# SKIP_ROBOT_LICENSE_CHECK=1

# 桌面端启动优化（避免重启卡死）
# TONJCLAW_SKIP_SCHEDULER=1
# TONJCLAW_VERBOSE_ROUTES=0
# HOOK_PROBE_TIMEOUT=1.5
# HOOK_RUNTIME_CACHE_MS=5000
# MIDDLEWARE_HEALTH_TIMEOUT=1
# 旧版推送路径（可选）
HOOK_CALLBACK_URL_GROUP=http://localhost:5000/主动推送的群聊消息
HOOK_CALLBACK_URL_PRIVATE=http://localhost:5000/主动推送的私聊消息
