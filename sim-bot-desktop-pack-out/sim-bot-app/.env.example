# TCP 微信 Hook 上行消息
TCP_HOST=0.0.0.0
TCP_PORT=61108

# Web 管理后台 + REST API
HTTP_HOST=0.0.0.0
HTTP_PORT=3000

# Hook DLL 回调本服务（默认与 HTTP_PORT 相同；打包桌面端仅开 3000 时必须走 3000）
# HOOK_CALLBACK_PORT=5000
# HOOK_CALLBACK_URL=http://127.0.0.1:3000/api/recvMsg
# 入站模式：http（推荐，打包版默认）| tcp
HOOK_RECEIVE_MODE=http

# Windows：进程启动后自动跑 scripts/launch-wechat-hook.mjs（0=关；1=强开；未设置且存在 hk/x64 inject.exe 时默认开）
# AUTO_WECHAT_INJECT=1
# 始终向 inject 传入 Weixin.exe 路径（可能再起一个微信），即使已有微信在运行
# WECHAT_INJECT_ALWAYS_LAUNCH=0

# Hook 控制面（本服务请求 Hook 开放在此端口，与注入 JSON 中 http_server_port 一致）
HOOK_API_BASE=http://127.0.0.1:19088
# 注入 JSON 里的 http_server_port（仅启动脚本 launch-wechat-hook 使用时可设）
# HOOK_DLL_HTTP_PORT=19088
HOOK_API_TOKEN=8888
# 入站 .txt 等附件 CDN 下载（逗号分隔 API 路径；留空则依次尝试常见路径）
# HOOK_CDN_DOWNLOAD_PATH=/api/download_attach
# HOOK_INBOUND_FILE_DIR=./data/inbound_attach

# 离线激活码验签：本服务只放公钥 PEM（旧版长码 RSA）；新版 32 位短码用下方密钥
ACTIVATION_PUBLIC_KEY_PATH=./keys/activation_public.pem
# 32 位短卡密 HMAC 密钥（须与发卡端 sales-portal/.env 中 ACTIVATION_CARD_SECRET 完全一致）
ACTIVATION_CARD_SECRET=change-me-card-secret-min-16-chars

# 若为 1，跳过「首次安装授权码」门禁（仅本地开发；正式版安装包请勿设置）
# 开发调试可复制到 .env：SKIP_PRODUCT_SETUP=1
SKIP_PRODUCT_SETUP=0

# 仅桌面首次启动：=1 时会先关已开微信再注入；默认 0=不关，已开则热注入，未开则 inject 拉起一次
# WECHAT_QUIT_BEFORE_INJECT=0

# JWT（管理后台登录）
JWT_SECRET=change-me-in-production

# ── 仅本机开发者：可选「无敌」超级账号（与 admin 同源权限，但每次启动会以 .env 口令覆盖哈希）
# 切勿随正式安装包或生产环境开启。
# DEV_SUPER_ENABLE=0
# DEV_SUPER_USERNAME=devgod
# DEV_SUPER_PASSWORD=min-8-chars-secret

# SQLite（群绑定 wx_groups、产品授权 app_settings、订单等均持久化于此；勿删 data/ 目录）
SQLITE_PATH=./data/sim_bot.db

# Tauri 打包后由桌面壳注入（开发态勿设）
# SIM_BOT_ROOT=
# WECHAT_HK_DIR=

# 入站去重 TTL（秒，进程内 Map，无需 Redis）
# INBOUND_DEDUPE_TTL_SEC=300
# 出站延迟队列兜底轮询（毫秒）
# OUTBOUND_QUEUE_POLL_MS=100
