{
  "name": "sim-bot-node",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prestart": "node scripts/ensure-admin-dist.mjs",
    "start": "node src/server.js",
    "predev": "node scripts/ensure-admin-dist.mjs",
    "dev": "node --watch src/server.js",
    "admin:dev": "npm --prefix admin run dev",
    "admin:build": "npm --prefix admin run build",
    "admin:preview": "npm --prefix admin run preview",
    "hook:launch": "node scripts/launch-wechat-hook.mjs",
    "sales:dev": "npm --prefix sales-portal run dev",
    "sales:start": "npm --prefix sales-portal start",
    "desktop:install": "npm --prefix desktop install",
    "desktop:start": "npm --prefix desktop start",
    "desktop:dist:win": "npm --prefix desktop run dist:win",
    "tauri:install": "npm --prefix desktop-tauri install",
    "tauri:dev": "npm --prefix desktop-tauri run dev",
    "tauri:prepare": "node desktop/scripts/prepare-win-pack.mjs",
    "tauri:build": "npm run tauri:prepare && npm --prefix desktop-tauri run build",
    "test:contract": "node scripts/contract-prd.mjs",
    "test:contract:xlsx": "node scripts/contract-play-spec-xlsx.mjs",
    "test:contract:e2e": "node scripts/contract-prd-e2e.mjs",
    "test:contract:rust": "node scripts/contract-prd-rust-parity.mjs",
    "test:contract:engine-rust": "node scripts/contract-prd-engine-rust.mjs",
    "verify:prd-layout": "node scripts/verify-prd-layout.mjs",
    "rust:prd:build": "cargo build --manifest-path desktop-tauri/src-tauri/Cargo.toml --bin sim-bot-prd",
    "desktop:deprecated": "echo Electron desktop 已弃用，请使用 npm run tauri:dev"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^2.1.1",
    "sql.js": "^1.12.0",
    "xlsx": "^0.18.5"
  }
}
